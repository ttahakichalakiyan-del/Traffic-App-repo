# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ctpl_traffic
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Authentication
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Firebase Cloud Messaging (base64-encoded service account JSON)
FCM_SERVICE_ACCOUNT=

# HERE Maps Traffic API
HERE_API_KEY=your-here-maps-api-key

# Chromium path for PDF generation (optional — auto-detected if omitted)
CHROMIUM_PATH=

# Timezone
TZ=Asia/Karachi

# Backend
BACKEND_URL=http://localhost:3001
PORT=3001
NODE_ENV=development

# ML Engine
ML_ENGINE_URL=http://localhost:8000

# Redis
REDIS_URL=redis://localhost:6379

# Admin Panel
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
